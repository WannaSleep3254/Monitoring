+QVariant jsonIntegerVariant(const QJsonValue& value)
+{
+    return value.isDouble()
+               ? QVariant(static_cast<qint64>(value.toDouble()))
+               : QVariant(QVariant::LongLong);
+}
+
+QVariant jsonBoolVariant(const QJsonValue& value)
+{
+    return value.isBool()
+               ? QVariant(value.toBool() ? 1 : 0)
+               : QVariant(QVariant::Int);
+}
+
+QString compactJsonValue(const QJsonValue& value)
+{
+    if (value.isObject()) {
+        return QString::fromUtf8(
+            QJsonDocument(value.toObject()).toJson(QJsonDocument::Compact));
+    }
+
+    if (value.isArray()) {
+        return QString::fromUtf8(
+            QJsonDocument(value.toArray()).toJson(QJsonDocument::Compact));
+    }
+
+    return QString();
+}
+
+QString payloadMessageType(const QByteArray& payload)
+{
+    QJsonParseError parseError;
+    const QJsonDocument doc = QJsonDocument::fromJson(payload, &parseError);
+
+    if (parseError.error != QJsonParseError::NoError || !doc.isObject()) {
+        return QString();
+    }
+
+    return doc.object().value(QStringLiteral("messageType")).toString();
+}
+
+bool isStructuredProcessMessageType(const QString& messageType)
+{
+    return messageType == QStringLiteral("processEvent") ||
+           messageType == QStringLiteral("processCommandEvent");
+}
