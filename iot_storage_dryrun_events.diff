+bool insertDryRunEvent(QSqlDatabase& db,
+                       const QString& topic,
+                       const QByteArray& payload)
+{
+    QJsonParseError parseError;
+    const QJsonDocument doc = QJsonDocument::fromJson(payload, &parseError);
+
+    if (parseError.error != QJsonParseError::NoError || !doc.isObject()) {
+        qWarning() << "[IoTStorageCollector] invalid dryRunEvent JSON skipped"
+                   << parseError.errorString();
+        return false;
+    }
+
+    const QJsonObject object = doc.object();
+    const QString messageType =
+        object.value(QStringLiteral("messageType")).toString();
+    if (messageType != QStringLiteral("dryRunEvent")) {
+        qWarning() << "[IoTStorageCollector] non-dryRunEvent skipped"
+                   << "topic =" << topic
+                   << "messageType =" << messageType;
+        return false;
+    }
+
+    const qint64 nowMs = QDateTime::currentMSecsSinceEpoch();
+    const QString nowIso =
+        QDateTime::fromMSecsSinceEpoch(nowMs).toString(Qt::ISODateWithMs);
+    const qint64 eventEpochMs = timestampEpochMs(object, nowMs);
+    const QString eventAt =
+        object.value(QStringLiteral("timestamp")).toString(
+            QDateTime::fromMSecsSinceEpoch(eventEpochMs)
+                .toString(Qt::ISODateWithMs));
+
+    const QJsonValue agentReceivedEpochValue =
+        object.value(QStringLiteral("agentReceivedEpochMs"));
+    const QVariant agentReceivedEpochMs =
+        agentReceivedEpochValue.isDouble()
+            ? QVariant(static_cast<qint64>(agentReceivedEpochValue.toDouble()))
+            : QVariant(QVariant::LongLong);
+    const QVariant robotId =
+        object.contains(QStringLiteral("robotId"))
+            ? jsonIntegerVariant(object.value(QStringLiteral("robotId")))
+            : QVariant(QVariant::Int);
+    const QString event =
+        object.value(QStringLiteral("event")).toString();
+    const QString detailJson =
+        compactJsonValue(object.value(QStringLiteral("detail")));
+
+    QSqlQuery query(db);
+    query.prepare(
+        QStringLiteral(
+            "INSERT INTO dry_run_events ("
+            "received_epoch_ms,"
+            "received_at,"
+            "agent_received_epoch_ms,"
+            "agent_received_at,"
+            "event_epoch_ms,"
+            "event_at,"
+            "topic,"
+            "schema_version,"
+            "robot_id,"
+            "run_id,"
+            "profile,"
+            "cycle,"
+            "event,"
+            "step,"
+            "step_index,"
+            "ok,"
+            "message,"
+            "detail_json,"
+            "raw_json"
+            ") VALUES ("
+            ":received_epoch_ms,"
+            ":received_at,"
+            ":agent_received_epoch_ms,"
+            ":agent_received_at,"
+            ":event_epoch_ms,"
+            ":event_at,"
+            ":topic,"
+            ":schema_version,"
+            ":robot_id,"
+            ":run_id,"
+            ":profile,"
+            ":cycle,"
+            ":event,"
+            ":step,"
+            ":step_index,"
+            ":ok,"
+            ":message,"
+            ":detail_json,"
+            ":raw_json"
+            ")"));
+
+    query.bindValue(QStringLiteral(":received_epoch_ms"), nowMs);
+    query.bindValue(QStringLiteral(":received_at"), nowIso);
+    query.bindValue(QStringLiteral(":agent_received_epoch_ms"),
+                    agentReceivedEpochMs);
+    query.bindValue(QStringLiteral(":agent_received_at"),
+                    object.value(QStringLiteral("agentReceivedAt")).toString());
+    query.bindValue(QStringLiteral(":event_epoch_ms"), eventEpochMs);
+    query.bindValue(QStringLiteral(":event_at"), eventAt);
+    query.bindValue(QStringLiteral(":topic"), topic);
+    query.bindValue(QStringLiteral(":schema_version"),
+                    jsonIntegerVariant(
+                        object.value(QStringLiteral("schemaVersion"))));
+    query.bindValue(QStringLiteral(":robot_id"), robotId);
+    query.bindValue(QStringLiteral(":run_id"),
+                    object.value(QStringLiteral("runId")).toString());
+    query.bindValue(QStringLiteral(":profile"),
+                    object.value(QStringLiteral("profile")).toString());
+    query.bindValue(QStringLiteral(":cycle"),
+                    jsonIntegerVariant(object.value(QStringLiteral("cycle"))));
+    query.bindValue(QStringLiteral(":event"), event);
+    query.bindValue(QStringLiteral(":step"),
+                    object.value(QStringLiteral("step")).toString());
+    query.bindValue(QStringLiteral(":step_index"),
+                    jsonIntegerVariant(
+                        object.value(QStringLiteral("stepIndex"))));
+    query.bindValue(QStringLiteral(":ok"),
+                    jsonBoolVariant(object.value(QStringLiteral("ok"))));
+    query.bindValue(QStringLiteral(":message"),
+                    object.value(QStringLiteral("message")).toString());
+    query.bindValue(QStringLiteral(":detail_json"), detailJson);
+    query.bindValue(QStringLiteral(":raw_json"), QString::fromUtf8(payload));
+
+    if (!query.exec()) {
+        qWarning() << "[IoTStorageCollector] dryRunEvent insert failed"
+                   << query.lastError().text()
+                   << "runId =" << object.value(QStringLiteral("runId")).toString()
+                   << "event =" << event
+                   << "step =" << object.value(QStringLiteral("step")).toString();
+        return false;
+    }
+
+    query.finish();
+    return true;
+}
